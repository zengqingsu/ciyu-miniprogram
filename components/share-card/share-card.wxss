/*components/share-card/share-card.wxss*/
.share-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px;
}

.card-canvas {
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
}

.share-buttons {
  display: flex;
  gap: 12px;
  margin-top: 20px;
}

.btn-share {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 24px;
  padding: 10px 24px;
  font-size: 14px;
}

.btn-share::after {
  border: none;
}