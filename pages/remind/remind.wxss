/* pages/remind/remind.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  text-align: center;
  padding: 40rpx 20rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #999;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.label {
  font-size: 32rpx;
  color: #333;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.picker {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  text-align: center;
}

.picker text {
  font-size: 36rpx;
  color: #667eea;
  font-weight: bold;
}

.radio-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.radio-item:last-child {
  border-bottom: none;
}

.radio-item text {
  margin-left: 20rpx;
  font-size: 30rpx;
  color: #333;
}

.preview {
  padding: 30rpx;
  background: #f0f5ff;
  border-radius: 12rpx;
  border: 1rpx dashed #667eea;
}

.preview text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
}

.save-btn {
  background: #667eea;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-top: 40rpx;
}

.save-btn text {
  font-size: 32rpx;
  font-weight: bold;
}
