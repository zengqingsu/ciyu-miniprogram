<!--pages/notebook/notebook.wxml-->
<view class="container">
  <view class="header">
    <text class="title">生词本</text>
    <text class="subtitle">收藏你记不住的单词</text>
  </view>
  
  <!-- 单词列表 -->
  <view class="word-list" wx:if="{{notebook.length > 0}}">
    <view class="word-item" wx:for="{{notebook}}" wx:key="id">
      <view class="word-info">
        <text class="word">{{item.word}}</text>
        <text class="phonetic">{{item.pronunciation}}</text>
      </view>
      <view class="word-meaning">
        <text>{{item.meaning}}</text>
      </view>
      <view class="word-example" wx:if="{{item.example}}">
        <text>{{item.example}}</text>
      </view>
      <view class="word-actions">
        <button class="study-btn" size="mini" bindtap="studyWord" data-word="{{item}}">学习</button>
        <button class="delete-btn" size="mini" bindtap="deleteWord" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty" wx:else>
    <text class="empty-icon">📚</text>
    <text class="empty-text">生词本为空</text>
    <text class="empty-hint">在学习过程中可以收藏单词</text>
  </view>
</view>
