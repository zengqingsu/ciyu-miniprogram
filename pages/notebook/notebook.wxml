<!--pages/notebook/notebook.wxml-->
<view class="container">
  <view class="header">
    <text class="title">生词本</text>
    <text class="subtitle">收藏你记不住的单词</text>
  </view>
  
  <!-- 统计和操作栏 -->
  <view class="toolbar" wx:if="{{notebook.length > 0}}">
    <view class="stats">
      <text>共 {{stats.total}} 个单词</text>
    </view>
    <view class="sort-btns">
      <text class="sort-btn {{sortType === 'time' ? 'active' : ''}}" bindtap="onSortChange" data-type="time">最新</text>
      <text class="sort-btn {{sortType === 'alpha' ? 'active' : ''}}" bindtap="onSortChange" data-type="alpha">字母</text>
    </view>
  </view>
  
  <!-- 搜索栏 -->
  <view class="search-bar" wx:if="{{notebook.length > 0}}">
    <input class="search-input" placeholder="搜索单词..." bindinput="onSearchInput" />
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-btns" wx:if="{{notebook.length > 0}}">
    <button class="export-btn" bindtap="exportNotebook">📋 导出</button>
  </view>
  
  <!-- 分类筛选 -->
  <view class="filter-bar" wx:if="{{categories.length > 0}}">
    <text class="filter-tag {{!filterCategory ? 'active' : ''}}" bindtap="onFilterChange" data-category="">全部</text>
    <text class="filter-tag {{filterCategory === item ? 'active' : ''}}" wx:for="{{categories}}" wx:key="*this" bindtap="onFilterChange" data-category="{{item}}">{{item}}</text>
  </view>
  
  <!-- 单词列表 -->
  <view class="word-list" wx:if="{{notebook.length > 0}}">
    <view class="word-item" wx:for="{{notebook}}" wx:key="id">
      <view class="word-info">
        <text class="word">{{item.word}}</text>
        <text class="phonetic">{{item.pronunciation}}</text>
      </view>
      <view class="word-meaning">
        <text>{{item.meaning}}</text>
      </view>
      <view class="word-example" wx:if="{{item.example}}">
        <text>{{item.example}}</text>
      </view>
      <view class="word-actions">
        <button class="study-btn" size="mini" bindtap="studyWord" data-word="{{item}}">学习</button>
        <button class="delete-btn" size="mini" bindtap="deleteWord" data-id="{{item.id}}">删除</button>
      </view>
    </view>
  </view>
  
  <!-- 空状态 -->
  <view class="empty" wx:else>
    <text class="empty-icon">📚</text>
    <text class="empty-text">生词本为空</text>
    <text class="empty-hint">在学习过程中可以收藏单词</text>
  </view>
</view>
