/* pages/review/review.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
}

.stats-section {
  display: flex;
  background: #fff;
  padding: 30rpx;
  margin: 20rpx;
  border-radius: 16rpx;
}

.stat-card {
  flex: 1;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.review-list {
  padding: 20rpx;
}

.review-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.review-item.answered {
  background: #f0f5ff;
}

.word-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.word {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.phonetic {
  font-size: 28rpx;
  color: #999;
}

.meaning-section {
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.meaning {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 15rpx;
}

.example {
  display: block;
  font-size: 26rpx;
  color: #666;
  font-style: italic;
}

.review-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.btn-again {
  flex: 1;
  background: #faad14 !important;
  color: #fff !important;
}

.btn-got {
  flex: 1;
  background: #52c41a !important;
  color: #fff !important;
}

.tap-hint {
  text-align: center;
  padding: 20rpx;
  color: #1890ff;
  font-size: 28rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 30rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

.retry-btn {
  margin-top: 40rpx;
  background: #667eea !important;
  color: #fff !important;
}

.bottom-actions {
  padding: 30rpx;
}

.review-all-btn {
  background: #667eea !important;
  color: #fff !important;
  border-radius: 50rpx;
}
