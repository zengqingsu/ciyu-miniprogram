/* pages/listen/listen.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
}

.header {
  text-align: center;
  color: #fff;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
}

.question-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
}

.play-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.play-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.play-text {
  font-size: 28rpx;
  color: #666;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  padding: 30rpx;
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.option.correct {
  background: #f6ffed;
  border-color: #52c41a;
  color: #52c41a;
}

.option.wrong {
  background: #fff1f0;
  border-color: #ff4d4f;
  color: #ff4d4f;
}

.hint {
  text-align: center;
}

.hint-btn {
  background: #1890ff;
  color: #fff;
  border-radius: 50rpx;
}

.next-btn {
  margin-top: 40rpx;
}

.next-btn button {
  background: #52c41a;
  color: #fff;
  border-radius: 50rpx;
}

.complete-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 30rpx;
  text-align: center;
}

.complete-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.complete-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 40rpx;
}

.score-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.score {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.score-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 10rpx;
}

.score-percent {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.complete-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.retry-btn {
  background: #667eea;
  color: #fff;
  border-radius: 50rpx;
}

.back-btn {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 50rpx;
}
