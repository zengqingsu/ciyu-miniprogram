<!--pages/search/search.wxml-->
<view class="container">
  <!-- 搜索框 -->
  <view class="search-box">
    <input class="search-input" placeholder="搜索单词..." value="{{keyword}}" bindinput="onInput" bindconfirm="onSearch" />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>
  
  <!-- 搜索结果 -->
  <view class="result-list" wx:if="{{results.length > 0}}">
    <view class="result-item" wx:for="{{results}}" wx:key="id">
      <view class="word-main">
        <text class="word">{{item.word}}</text>
        <text class="phonetic">{{item.pronunciation}}</text>
      </view>
      <view class="word-meaning">{{item.meaning}}</view>
      <view class="word-example" wx:if="{{item.example}}">{{item.example}}</view>
      <view class="word-tags">
        <text class="tag level">难度{{item.level}}</text>
        <text class="tag category">{{item.category}}</text>
      </view>
      <view class="word-actions">
        <button class="action-btn study" size="mini" bindtap="studyWord" data-word="{{item}}">学习</button>
        <button class="action-btn notebook" size="mini" bindtap="addToNotebook" data-word="{{item}}">⭐ 收藏</button>
      </view>
    </view>
  </view>
  
  <!-- 搜索历史 -->
  <view class="section" wx:elif="{{history.length > 0 && !searched}}">
    <view class="section-header">
      <text class="section-title">搜索历史</text>
      <text class="clear-btn" bindtap="clearHistory">清除</text>
    </view>
    <view class="history-list">
      <text class="history-item" wx:for="{{history}}" wx:key="*this" bindtap="onHotWordTap" data-word="{{item}}">{{item}}</text>
    </view>
  </view>
  
  <!-- 热门搜索 -->
  <view class="section" wx:elif="{{!searched}}">
    <text class="section-title">热门搜索</text>
    <view class="hot-list">
      <text class="hot-item" wx:for="{{hotWords}}" wx:key="*this" bindtap="onHotWordTap" data-word="{{item}}">{{item}}</text>
    </view>
  </view>
  
  <!-- 无结果 -->
  <view class="empty" wx:elif="{{searched}}">
    <text>未找到匹配的单词</text>
  </view>
</view>
