/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.search-box {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  padding: 10rpx 20rpx;
}

.search-btn {
  background: #667eea;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
}

.result-list {
  padding: 0 10rpx;
}

.result-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.word-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 15rpx;
}

.word {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.phonetic {
  font-size: 28rpx;
  color: #999;
}

.word-meaning {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.word-example {
  font-size: 26rpx;
  color: #999;
  font-style: italic;
  margin-bottom: 15rpx;
}

.word-tags {
  display: flex;
  gap: 15rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.tag.level {
  background: #e6f7ff;
  color: #1890ff;
}

.tag.category {
  background: #f6ffed;
  color: #52c41a;
}

.empty, .hint {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
