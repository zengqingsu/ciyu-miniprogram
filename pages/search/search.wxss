/* pages/search/search.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.search-box {
  display: flex;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  padding: 10rpx 20rpx;
}

.search-btn {
  background: #667eea;
  color: #fff;
  font-size: 28rpx;
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
}

/* Loading */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.clear-btn {
  font-size: 26rpx;
  color: #999;
}

/* 搜索历史 */
.history-list, .hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.history-item, .hot-item {
  background: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  color: #666;
}

.history-item:active, .hot-item:active {
  background: #e8e8e8;
}

.result-list {
  padding: 0 10rpx;
}

.result-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.word-main {
  display: flex;
  align-items: baseline;
  margin-bottom: 15rpx;
}

.word {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-right: 20rpx;
}

.phonetic {
  font-size: 28rpx;
  color: #999;
}

.word-meaning {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.word-example {
  font-size: 26rpx;
  color: #999;
  font-style: italic;
  margin-bottom: 15rpx;
}

.word-tags {
  display: flex;
  gap: 15rpx;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.tag.level {
  background: #e6f7ff;
  color: #1890ff;
}

.tag.category {
  background: #f6ffed;
  color: #52c41a;
}

.word-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  font-size: 26rpx;
  padding: 15rpx 0;
}

.action-btn.study {
  background: #667eea;
  color: #fff;
}

.action-btn.notebook {
  background: #ffd700;
  color: #333;
}

.empty, .hint {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
