/* index.wxss */
.container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  margin-top: 100rpx;
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
  display: block;
}

.stats {
  display: flex;
  justify-content: space-around;
  width: 100%;
  margin-bottom: 80rpx;
}

.stat-item {
  text-align: center;
}

.num {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
  display: block;
}

.label {
  font-size: 24rpx;
  color: #999;
}

.start-btn {
  width: 80%;
  background: #1890ff;
  color: white;
  border-radius: 50rpx;
  padding: 20rpx 0;
}
