/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx;
}

/* 头部 */
.header {
  text-align: center;
  padding: 60rpx 0;
}

.title {
  display: block;
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 统计卡片 */
.stats-card {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid #eee;
}

.stat-item:last-child {
  border-right: none;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 10rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 今日推荐 */
.today-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.words-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.word-item {
  width: calc(50% - 10rpx);
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.word-text {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.word-meaning {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 快捷入口 */
.quick-entry {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.entry-item {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  margin: 0 10rpx;
  box-shadow: 0 5rpx 20rpx rgba(0, 0, 0, 0.1);
}

.entry-item:first-child {
  margin-left: 0;
}

.entry-item:last-child {
  margin-right: 0;
}

.entry-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.entry-text {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 开始学习按钮 */
.start-btn {
  background: #52c41a;
  border-radius: 50rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 10rpx 30rpx rgba(82, 196, 26, 0.4);
}

.start-btn text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.start-btn:active {
  transform: scale(0.98);
}

/* 提示 */
.tip {
  text-align: center;
  margin-top: 40rpx;
}

.tip text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}
