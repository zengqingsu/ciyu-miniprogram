<!--pages/index/index.wxml-->
<view class="container">
  <!-- Loading 状态 -->
  <view class="loading-mask" wx:if="{{isLoading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>
  
  <!-- 头部 -->
  <view class="header">
    <text class="greeting">{{greeting}} 👋</text>
    <text class="title">词途</text>
    <text class="subtitle">让背单词变得更简单</text>
  </view>
  
  <!-- 每日目标 -->
  <view class="goal-card">
    <view class="goal-header">
      <text class="goal-title">今日目标</text>
      <text class="goal-progress">{{todayProgress}}/{{dailyGoal}} 词</text>
    </view>
    <view class="goal-progress-bar">
      <view class="goal-progress-fill" style="width: {{todayProgress/dailyGoal*100}}%"></view>
    </view>
  </view>
  
  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.total || 0}}</text>
      <text class="stat-label">总学习</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.known || 0}}</text>
      <text class="stat-label">已掌握</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.unknown || 0}}</text>
      <text class="stat-label">待复习</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.progress || 0}}%</text>
      <text class="stat-label">掌握率</text>
    </view>
  </view>
  
  <!-- 今日单词预览 -->
  <view class="today-section">
    <view class="section-header">
      <text class="section-title">今日推荐</text>
      <text class="section-tip">点击开始学习</text>
    </view>
    <view class="words-list">
      <view class="word-item" wx:for="{{todayWords}}" wx:key="id" bindtap="goToWord" data-word="{{item}}">
        <view class="word-top">
          <text class="word-text">{{item.word}}</text>
          <text class="word-level" wx:if="{{item.level}}">Lv{{item.level}}</text>
        </view>
        <text class="word-meaning">{{item.meaning}}</text>
      </view>
    </view>
  </view>
  
  <!-- 快捷入口 -->
  <view class="quick-entry">
    <view class="entry-item" bindtap="goToDaily">
      <text class="entry-icon">📅</text>
      <text class="entry-text">每日任务</text>
    </view>
    <view class="entry-item" bindtap="goToCategory">
      <text class="entry-icon">📂</text>
      <text class="entry-text">分类学习</text>
    </view>
    <view class="entry-item" bindtap="goToQuiz">
      <text class="entry-icon">📝</text>
      <text class="entry-text">能力测试</text>
    </view>
  </view>
  
  <!-- 更多快捷操作 -->
  <view class="quick-actions">
    <view class="action-item" bindtap="goToReview">
      <text class="action-icon">📖</text>
      <text class="action-text">错题复习</text>
    </view>
    <view class="action-item" bindtap="goToNotebook">
      <text class="action-icon">⭐</text>
      <text class="action-text">生词本</text>
    </view>
    <view class="action-item" bindtap="goToListen">
      <text class="action-icon">👂</text>
      <text class="action-text">听力练习</text>
    </view>
    <view class="action-item" bindtap="goToSearch">
      <text class="action-icon">🔍</text>
      <text class="action-text">单词搜索</text>
    </view>
    <view class="action-item" bindtap="goToPlan">
      <text class="action-icon">📋</text>
      <text class="action-text">学习计划</text>
    </view>
  </view>
  
  <!-- 开始学习按钮 -->
  <view class="start-btn" bindtap="goToLearn">
    <text>开始学习</text>
  </view>
  
  <!-- 底部导航提示 -->
  <view class="tip">
    <text>点击底部「学习」标签开始背单词</text>
  </view>
</view>
