<!--pages/index/index.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <text class="title">词途</text>
    <text class="subtitle">让背单词变得更简单</text>
  </view>
  
  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{stats.total || 0}}</text>
      <text class="stat-label">总学习</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.known || 0}}</text>
      <text class="stat-label">已掌握</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.unknown || 0}}</text>
      <text class="stat-label">待复习</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{stats.progress || 0}}%</text>
      <text class="stat-label">掌握率</text>
    </view>
  </view>
  
  <!-- 今日单词预览 -->
  <view class="today-section">
    <text class="section-title">今日推荐</text>
    <view class="words-list">
      <view class="word-item" wx:for="{{todayWords}}" wx:key="id">
        <text class="word-text">{{item.word}}</text>
        <text class="word-meaning">{{item.meaning}}</text>
      </view>
    </view>
  </view>
  
  <!-- 快捷入口 -->
  <view class="quick-entry">
    <view class="entry-item" bindtap="goToCategory">
      <text class="entry-icon">📂</text>
      <text class="entry-text">分类学习</text>
    </view>
    <view class="entry-item" bindtap="goToQuiz">
      <text class="entry-icon">📝</text>
      <text class="entry-text">能力测试</text>
    </view>
    <view class="entry-item" bindtap="goToNotebook">
      <text class="entry-icon">⭐</text>
      <text class="entry-text">生词本</text>
    </view>
  </view>
  
  <!-- 开始学习按钮 -->
  <view class="start-btn" bindtap="goToLearn">
    <text>开始学习</text>
  </view>
  
  <!-- 底部导航提示 -->
  <view class="tip">
    <text>点击底部「学习」标签开始背单词</text>
  </view>
</view>
