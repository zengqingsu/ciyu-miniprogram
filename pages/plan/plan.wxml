<!--pages/plan/plan.wxml-->
<view class="container">
  <view class="header">
    <text class="title">学习计划</text>
    <text class="subtitle">制定你的背单词目标</text>
  </view>
  
  <!-- 目标设置 -->
  <view class="section">
    <text class="section-title">每日目标</text>
    <view class="goal-options">
      <view class="goal-item {{dailyGoal === 5 ? 'active' : ''}}" bindtap="setGoal" data-goal="5">
        <text class="goal-num">5</text>
        <text class="goal-label">词/天</text>
      </view>
      <view class="goal-item {{dailyGoal === 10 ? 'active' : ''}}" bindtap="setGoal" data-goal="10">
        <text class="goal-num">10</text>
        <text class="goal-label">词/天</text>
      </view>
      <view class="goal-item {{dailyGoal === 20 ? 'active' : ''}}" bindtap="setGoal" data-goal="20">
        <text class="goal-num">20</text>
        <text class="goal-label">词/天</text>
      </view>
      <view class="goal-item {{dailyGoal === 30 ? 'active' : ''}}" bindtap="setGoal" data-goal="30">
        <text class="goal-num">30</text>
        <text class="goal-label">词/天</text>
      </view>
    </view>
    <view class="custom-goal">
      <text class="custom-label">自定义目标：</text>
      <input class="custom-input" type="number" value="{{customGoal}}" placeholder="输入每日目标" bindinput="inputCustomGoal" bindconfirm="setCustomGoal" confirm-type="done"/>
      <view class="custom-btn" bindtap="setCustomGoal">确定</view>
    </view>
  </view>
  
  <!-- 提醒设置 -->
  <view class="section">
    <text class="section-title">学习提醒</text>
    <view class="reminder-toggle">
      <text class="toggle-label">每日提醒</text>
      <switch checked="{{reminderEnabled}}" bindchange="toggleReminder" color="#667eea"/>
    </view>
    <view class="reminder-options" wx:if="{{reminderEnabled}}">
      <view class="time-picker">
        <text class="picker-label">提醒时间</text>
        <picker mode="time" value="{{reminderTime}}" bindchange="onTimeChange">
          <text class="picker-value">{{reminderTime}}</text>
        </picker>
      </view>
      <view class="days-picker">
        <text class="picker-label">重复日期</text>
        <view class="days-grid">
          <view class="day-item {{reminderDays.indexOf('0') > -1 ? 'active' : ''}}" bindtap="toggleDay" data-index="0">日</view>
          <view class="day-item {{reminderDays.indexOf('1') > -1 ? 'active' : ''}}" bindtap="toggleDay" data-index="1">一</view>
          <view class="day-item {{reminderDays.indexOf('2') > -1 ? 'active' : ''}}" bindtap="toggleDay" data-index="2">二</view>
          <view class="day-item {{reminderDays.indexOf('3') > -1 ? 'active' : ''}}" bindtap="toggleDay" data-index="3">三</view>
          <view class="day-item {{reminderDays.indexOf('4') > -1 ? 'active' : ''}}" bindtap="toggleDay" data-index="4">四</view>
          <view class="day-item {{reminderDays.indexOf('5') > -1 ? 'active' : ''}}" bindtap="toggleDay" data-index="5">五</view>
          <view class="day-item {{reminderDays.indexOf('6') > -1 ? 'active' : ''}}" bindtap="toggleDay" data-index="6">六</view>
        </view>
      </view>
      <view class="test-btn" bindtap="testReminder">测试提醒</view>
    </view>
  </view>
  
  <!-- 计划周期 -->
  <view class="section">
    <text class="section-title">计划周期</text>
    <view class="plan-info">
      <text>预计完成天数：{{ Math.ceil(totalWords / dailyGoal) }} 天</text>
      <text>完成进度：{{ Math.round((1 - (remainingWords / totalWords)) * 100) }}%</text>
    </view>
  </view>
  
  <!-- 统计 -->
  <view class="section">
    <text class="section-title">学习统计</text>
    <view class="stats-grid">
      <view class="stat-box">
        <text class="stat-num">{{totalWords}}</text>
        <text class="stat-label">总词数</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{learnedWords}}</text>
        <text class="stat-label">已学完</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{remainingWords}}</text>
        <text class="stat-label">剩余</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{daysLeft}}</text>
        <text class="stat-label">预计天数</text>
      </view>
    </view>
  </view>
</view>
