/*pages/leaderboard/leaderboard.wxss*/
.leaderboard {
  min-height: 100vh;
  background: linear-gradient(180deg, #667eea 0%, #764ba2 100%);
  padding: 20px;
}

.tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24px;
  padding: 4px;
  margin-bottom: 20px;
}

.tab {
  flex: 1;
  text-align: center;
  color: rgba(255, 255, 255, 0.8);
  padding: 10px 0;
  border-radius: 20px;
  font-size: 14px;
  transition: all 0.3s;
}

.tab.active {
  background: white;
  color: #667eea;
  font-weight: bold;
}

.my-rank {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 12px;
  padding: 16px 20px;
  margin-bottom: 16px;
}

.rank-label {
  color: #666;
  font-size: 14px;
}

.rank-value {
  color: #667eea;
  font-size: 18px;
  font-weight: bold;
}

.rank-list {
  background: white;
  border-radius: 16px;
  overflow: hidden;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 16px;
  border-bottom: 1px solid #f0f0f0;
}

.rank-item.top-1 {
  background: linear-gradient(90deg, #ffd700 0%, #ffb800 100%);
}

.rank-item.top-2 {
  background: linear-gradient(90deg, #c0c0c0 0%, #a8a8a8 100%);
}

.rank-item.top-3 {
  background: linear-gradient(90deg, #cd7f32 0%, #b87333 100%);
}

.rank-num {
  width: 28px;
  height: 28px;
  line-height: 28px;
  text-align: center;
  font-size: 16px;
  font-weight: bold;
  color: #333;
  margin-right: 12px;
}

.top-1 .rank-num { color: #fff; }
.top-2 .rank-num { color: #fff; }
.top-3 .rank-num { color: #fff; }

.avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  margin-right: 12px;
  background: #eee;
}

.info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 16px;
  color: #333;
  margin-bottom: 4px;
}

.score {
  font-size: 14px;
  color: #666;
}

.top-1 .nickname,
.top-2 .nickname,
.top-3 .nickname,
.top-1 .score,
.top-2 .score,
.top-3 .score {
  color: white;
}

.empty {
  text-align: center;
  padding: 40px;
  color: #999;
}