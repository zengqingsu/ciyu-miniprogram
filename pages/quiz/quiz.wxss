/* pages/quiz/quiz.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
}

/* 模式选择 */
.mode-selector {
  display: flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: 32rpx;
}

.mode-btn.active {
  background: #fff;
  color: #667eea;
  font-weight: bold;
}

/* 进度 */
.progress-section {
  margin-bottom: 30rpx;
}

.progress-bar {
  height: 10rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 5rpx;
  margin-bottom: 10rpx;
}

.progress-fill {
  height: 100%;
  background: #52c41a;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.progress-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 26rpx;
  text-align: center;
  display: block;
}

/* 题目卡片 */
.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 30rpx;
}

.word-display {
  text-align: center;
  margin-bottom: 40rpx;
}

.word {
  font-size: 60rpx;
  font-weight: bold;
  color: #333;
}

/* 选项 */
.options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option {
  padding: 30rpx;
  background: #f5f5f5;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  text-align: left;
}

.option.selected {
  background: #e6f7ff;
  border-color: #1890ff;
}

.option.correct {
  background: #f6ffed;
  border-color: #52c41a;
  color: #52c41a;
}

.option.wrong {
  background: #fff1f0;
  border-color: #ff4d4f;
  color: #ff4d4f;
}

/* 听力 */
.listen-section {
  text-align: center;
}

.listen-btn {
  background: #1890ff;
  color: #fff;
  padding: 30rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
}

/* 结果 */
.result-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
}

.result-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.result-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.correct-answer {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
}

.correct-answer text {
  font-size: 28rpx;
  color: #666;
}

/* 下一题按钮 */
.next-btn button {
  background: #52c41a;
  color: #fff;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
}

/* 完成页面 */
.complete-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 30rpx;
  text-align: center;
}

.complete-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.complete-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 40rpx;
}

.score-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx;
  margin-bottom: 40rpx;
}

.score {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.score-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  display: block;
  margin-bottom: 10rpx;
}

.score-percent {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  display: block;
}

.complete-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.retry-btn {
  background: #667eea;
  color: #fff;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
}

.back-btn {
  background: #fff;
  color: #667eea;
  border: 2rpx solid #667eea;
  border-radius: 50rpx;
  padding: 25rpx;
  font-size: 32rpx;
}
