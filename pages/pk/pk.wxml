<!--pages/pk/pk.wxml-->
<view class="pk-page">
  <!-- 创建PK -->
  <view class="create-section" wx:if="{{mode === 'create'}}">
    <view class="title">好友PK</view>
    <view class="desc">与好友比拼学习成果</view>
    <view class="my-stats">
      <view class="stat-item">
        <text class="value">{{myTotal}}</text>
        <text class="label">总词汇量</text>
      </view>
      <view class="stat-item">
        <text class="value">{{myStreak}}</text>
        <text class="label">连续天数</text>
      </view>
    </view>
    <button class="btn-create" bindtap="createPK">发起PK挑战</button>
  </view>

  <!-- 等待对手 -->
  <view class="waiting-section" wx:if="{{mode === 'waiting'}}">
    <view class="title">等待对手</view>
    <view class="pk-id">PK房间: {{pkId}}</view>
    <button class="btn-share" open-type="share">邀请好友</button>
    <view class="tip">分享链接给好友来加入PK</view>
  </view>

  <!-- PK中 -->
  <view class="battling-section" wx:if="{{mode === 'battling'}}">
    <view class="vs">VS</view>
    <view class="players">
      <view class="player player-a">
        <image class="avatar" src="{{playerA.avatarUrl || '/images/default-avatar.png'}}"/>
        <text class="name">{{playerA.nickName}}</text>
        <text class="score">{{playerA.total}}</text>
      </view>
      <view class="player player-b">
        <image class="avatar" src="{{playerB.avatarUrl || '/images/default-avatar.png'}}"/>
        <text class="name">{{playerB.nickName}}</text>
        <text class="score">{{playerB.total}}</text>
      </view>
    </view>
    
    <view class="result" wx:if="{{winner}}">
      <text wx:if="{{winner === 'playerA'}}">你赢了！🎉</text>
      <text wx:else>你输了 😢</text>
    </view>
  </view>
</view>