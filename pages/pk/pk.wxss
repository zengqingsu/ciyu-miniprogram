/*pages/pk/pk.wxss*/
.pk-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40px 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.title {
  font-size: 32px;
  font-weight: bold;
  color: white;
  margin-bottom: 12px;
}

.desc {
  font-size: 16px;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 40px;
}

.my-stats {
  display: flex;
  gap: 40px;
  margin-bottom: 40px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item .value {
  font-size: 36px;
  font-weight: bold;
  color: white;
}

.stat-item .label {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.7);
}

.btn-create {
  background: white;
  color: #667eea;
  border: none;
  border-radius: 30px;
  padding: 14px 48px;
  font-size: 18px;
  font-weight: bold;
}

.waiting-section {
  text-align: center;
}

.pk-id {
  color: white;
  margin: 20px 0;
  font-size: 14px;
}

.btn-share {
  background: #ffd700;
  color: #333;
  border: none;
  border-radius: 24px;
  padding: 12px 32px;
  font-size: 16px;
}

.tip {
  color: rgba(255, 255, 255, 0.7);
  font-size: 14px;
  margin-top: 16px;
}

.battling-section {
  width: 100%;
}

.vs {
  font-size: 48px;
  font-weight: bold;
  color: white;
  text-align: center;
  margin-bottom: 40px;
}

.players {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.player {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.player .avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 4px solid white;
  margin-bottom: 12px;
}

.player .name {
  color: white;
  font-size: 18px;
  margin-bottom: 8px;
}

.player .score {
  color: #ffd700;
  font-size: 32px;
  font-weight: bold;
}

.result {
  text-align: center;
  margin-top: 40px;
  font-size: 28px;
  color: white;
  font-weight: bold;
}