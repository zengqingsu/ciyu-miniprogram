<!--pages/learn/learn.wxml-->
<view class="container">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>
  
  <!-- 统计信息 -->
  <view class="stats">
    <text>今日学习: {{learnedCount}} 词</text>
    <text>认识: {{stats.known || 0}}</text>
    <text>不认识: {{stats.unknown || 0}}</text>
  </view>
  
  <!-- 单词卡片 -->
  <view class="card">
    <!-- 导航栏 -->
    <view class="card-nav" wx:if="{{history.length > 0}}">
      <text class="nav-btn" bindtap="prevWord">← 上一词</text>
      <text class="nav-count">已学 {{history.length}} 词</text>
      <text class="nav-placeholder"></text>
    </view>
    
    <!-- 单词 -->
    <view class="word-section">
      <view class="word-header">
        <text class="word" bindtap="playAudio" bindlongpress="copyWord">{{word.word}}</text>
        <text class="category-tag" wx:if="{{word.category}}">{{word.category}}</text>
      </view>
      <text class="phonetic">{{word.pronunciation}}</text>
      
      <!-- 发音控制 -->
      <view class="audio-controls">
        <view class="audio-icon" bindtap="playAudio">
          <text>🔊</text>
        </view>
        <view class="speed-control">
          <text class="speed-label">速度:</text>
          <view class="speed-btn {{speechRate === 0.75 ? 'active' : ''}}" bindtap="changeSpeed" data-rate="0.75">慢</view>
          <view class="speed-btn {{speechRate === 1.0 ? 'active' : ''}}" bindtap="changeSpeed" data-rate="1.0">普</view>
          <view class="speed-btn {{speechRate === 1.25 ? 'active' : ''}}" bindtap="changeSpeed" data-rate="1.25">快</view>
        </view>
      </view>
    </view>
    
    <!-- 释义（点击显示） -->
    <view class="meaning-section" bindtap="showAnswer" wx:if="{{!showMeaning}}">
      <text class="tap-hint">点击显示释义</text>
    </view>
    
    <view class="meaning-detail" wx:if="{{showMeaning}}">
      <text class="meaning">{{word.meaning}}</text>
      <text class="example" wx:if="{{word.example}}">{{word.example}}</text>
      <view class="level-badge" wx:if="{{word.level}}">
        <text>难度{{word.level}}</text>
      </view>
      <view class="notebook-btn" bindtap="addToNotebook">
        <text>⭐ 加入生词本</text>
      </view>
    </view>
  </view>
  
  <!-- 操作按钮 -->
  <view class="actions">
    <button class="btn-unknown" bindtap="markForget" disabled="{{isAnimating}}">
      不认识
    </button>
    <button class="btn-show" bindtap="showAnswer" wx:if="{{!showMeaning}}">
      显示释义
    </button>
    <button class="btn-known" bindtap="markKnow" wx:if="{{showMeaning}}" disabled="{{isAnimating}}">
      认识
    </button>
  </view>
  
  <!-- 跳过按钮 -->
  <view class="skip" bindtap="skipWord">
    <text>跳过</text>
  </view>
</view>
