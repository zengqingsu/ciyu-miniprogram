/* learn.wxss */
.container { padding: 30rpx; }
.word-card {
  background: #fff;
  padding: 60rpx;
  border-radius: 20rpx;
  text-align: center;
  margin: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}
.word { font-size: 48rpx; font-weight: bold; display: block; }
.phonetic { color: #666; font-size: 28rpx; display: block; margin: 20rpx 0; }
.meaning { color: #1890ff; font-size: 36rpx; }
.actions { display: flex; justify-content: space-around; margin-top: 60rpx; }
.btn { width: 40%; }
.forget { background: #ff4d4f; color: white; }
.know { background: #52c41a; color: white; }
