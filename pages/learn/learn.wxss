/* pages/learn/learn.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}

/* 进度条 */
.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  margin-bottom: 30rpx;
}

.progress-fill {
  height: 100%;
  background: #4caf50;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* 统计信息 */
.stats {
  display: flex;
  justify-content: space-around;
  color: rgba(255, 255, 255, 0.9);
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

/* 单词卡片 */
.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 500rpx;
}

.word-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.word {
  display: inline-block;
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.word:active {
  color: #667eea;
}

.word-header {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.category-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #667eea;
  background: rgba(102, 126, 234, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.audio-icon {
  display: inline-block;
  font-size: 48rpx;
  margin-left: 20rpx;
  opacity: 0.6;
}

.audio-icon:active {
  opacity: 1;
}

.phonetic {
  display: block;
  font-size: 36rpx;
  color: #999;
}

.meaning-section {
  text-align: center;
  padding: 60rpx 0;
}

.tap-hint {
  font-size: 32rpx;
  color: #1890ff;
  padding: 20rpx 40rpx;
  border: 2rpx dashed #1890ff;
  border-radius: 12rpx;
}

.meaning-detail {
  text-align: center;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.meaning {
  display: block;
  font-size: 40rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 30rpx;
}

.example {
  display: block;
  font-size: 28rpx;
  color: #666;
  font-style: italic;
  line-height: 1.8;
}

.level-badge {
  display: inline-block;
  margin-top: 30rpx;
  padding: 8rpx 24rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
}

.level-badge text {
  font-size: 24rpx;
  color: #666;
}

.notebook-btn {
  display: inline-block;
  margin-top: 30rpx;
  padding: 15rpx 30rpx;
  background: linear-gradient(135deg, #ffd700, #ffb800);
  border-radius: 30rpx;
}

.notebook-btn text {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

/* 操作按钮 */
.actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.actions button {
  flex: 1;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  border: none;
}

.btn-unknown {
  background: #ff4d4f;
  color: #fff;
}

.btn-unknown:active {
  background: #d9363e;
}

.btn-show {
  background: #1890ff;
  color: #fff;
}

.btn-show:active {
  background: #096dd9;
}

.btn-known {
  background: #52c41a;
  color: #fff;
}

.btn-known:active {
  background: #389e0d;
}

/* 跳过按钮 */
.skip {
  text-align: center;
  margin-top: 30rpx;
}

.skip text {
  color: rgba(255, 255, 255, 0.7);
  font-size: 28rpx;
  padding: 20rpx;
}

/* 动画 */
@keyframes slideOut {
  from { transform: translateX(0); opacity: 1; }
  to { transform: translateX(-100%); opacity: 0; }
}

.card.animating {
  animation: slideOut 0.3s ease forwards;
}
