/* pages/daily/daily.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
}

.progress-section {
  background: #fff;
  padding: 40rpx;
  text-align: center;
}

.progress-ring {
  display: inline-block;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.progress-num {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
}

.progress-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.task-list {
  padding: 20rpx;
}

.task-item {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.task-item.completed {
  background: #f6ffed;
}

.task-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.task-info {
  flex: 1;
}

.task-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.task-desc {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
}

.task-progress {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.task-progress .progress-bar {
  flex: 1;
  height: 10rpx;
  background: #f0f0f0;
  border-radius: 5rpx;
}

.task-progress .progress-fill {
  height: 100%;
  background: #52c41a;
  border-radius: 5rpx;
}

.task-progress .progress-text {
  font-size: 24rpx;
  color: #999;
  min-width: 80rpx;
  text-align: right;
}

.tip {
  text-align: center;
  padding: 40rpx;
  color: #666;
  font-size: 28rpx;
}
