/* pages/trend/trend.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 0 120rpx;
}

.header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.tab-container {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx 30rpx;
}

.tab-item {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #fff;
  border-radius: 32rpx;
  border: 2rpx solid #e0e0e0;
}

.tab-item.active {
  color: #fff;
  background: #409eff;
  border-color: #409eff;
}

.chart-container {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.trend-canvas {
  width: 100%;
  height: 400rpx;
}

.stats-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 30rpx;
  margin: 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-item {
  text-align: center;
  padding: 20rpx;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #409eff;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.share-btn {
  width: 100%;
  background: linear-gradient(135deg, #409eff, #67c23a);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}