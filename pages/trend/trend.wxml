<!-- pages/trend/trend.wxml -->
<view class="container">
  <view class="header">
    <text class="title">学习趋势</text>
    <text class="subtitle">每日学习时长统计</text>
  </view>

  <!-- 时间选择 -->
  <view class="tab-container">
    <view class="tab-item {{days === 7 ? 'active' : ''}}" bindtap="changeDays" data-days="7">7天</view>
    <view class="tab-item {{days === 14 ? 'active' : ''}}" bindtap="changeDays" data-days="14">14天</view>
    <view class="tab-item {{days === 30 ? 'active' : ''}}" bindtap="changeDays" data-days="30">30天</view>
  </view>

  <!-- 趋势图 -->
  <view class="chart-container">
    <canvas type="2d" id="trendCanvas" class="trend-canvas"></canvas>
  </view>

  <!-- 今日统计 -->
  <view class="stats-container" wx:if="{{stats}}">
    <view class="stat-item">
      <text class="stat-value">{{stats.studyMinutes}}</text>
      <text class="stat-label">今日学习(分钟)</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.newWords}}</text>
      <text class="stat-label">新学单词</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.reviewWords}}</text>
      <text class="stat-label">复习单词</text>
    </view>
    <view class="stat-item">
      <text class="stat-value">{{stats.streak}}</text>
      <text class="stat-label">连续学习(天)</text>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="action-bar">
    <button class="share-btn" bindtap="onShareAppMessage" open-type="share">分享给好友</button>
  </view>
</view>