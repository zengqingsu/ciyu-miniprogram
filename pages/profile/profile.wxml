<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <text class="title">个人中心</text>
  </view>
  
  <!-- 学习统计 -->
  <view class="section">
    <text class="section-title">学习统计</text>
    <view class="stats-grid">
      <view class="stat-box">
        <text class="stat-num">{{stats.total || 0}}</text>
        <text class="stat-label">总学习</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{stats.known || 0}}</text>
        <text class="stat-label">已掌握</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{stats.unknown || 0}}</text>
        <text class="stat-label">待复习</text>
      </view>
      <view class="stat-box">
        <text class="stat-num">{{stats.progress || 0}}%</text>
        <text class="stat-label">掌握率</text>
      </view>
    </view>
  </view>
  
  <!-- 学习进度 -->
  <view class="section">
    <text class="section-title">学习进度</text>
    <view class="progress-card">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{stats.progress || 0}}%"></view>
      </view>
      <text class="progress-text">已完成 {{stats.progress || 0}}%</text>
    </view>
  </view>
  
  <!-- 已学单词列表 -->
  <view class="section" wx:if="{{records.known && records.known.length > 0}}">
    <text class="section-title">已掌握单词</text>
    <view class="words-list">
      <text class="word-tag" wx:for="{{records.known}}" wx:key="*this">单词{{item}}</text>
    </view>
  </view>
  
  <!-- 操作 -->
  <view class="section">
    <button class="plan-btn" bindtap="goToPlan">📈 学习计划</button>
    <button class="daily-btn" bindtap="goToDaily">📅 每日任务</button>
    <button class="search-btn" bindtap="goToSearch">🔍 单词搜索</button>
    <button class="achievement-btn" bindtap="goToAchievement">🏆 成就徽章</button>
    <button class="quiz-btn" bindtap="goToQuiz">📝 能力测试</button>
    <button class="notebook-btn" bindtap="goToNotebook">📚 生词本 ({{stats.notebookCount || 0}})</button>
    <button class="setting-btn" bindtap="goToSettings">API设置</button>
    <button class="remind-btn" bindtap="goToRemind">学习提醒</button>
    <button class="clear-btn" bindtap="clearRecords">清除记录</button>
  </view>
  
  <!-- 版本信息 -->
  <view class="footer">
    <text>词途小程序 v1.0</text>
    <text>让背单词变得更简单</text>
  </view>
</view>
