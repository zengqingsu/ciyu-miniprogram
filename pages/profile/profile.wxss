/* pages/profile/profile.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

/* 头部 */
.header {
  padding: 40rpx 20rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-box {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 30rpx;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 10rpx;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 进度条 */
.progress-card {
  padding: 20rpx 0;
}

.progress-bar {
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 15rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
  text-align: right;
  display: block;
}

/* 单词列表 */
.words-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.word-tag {
  display: inline-block;
  padding: 10rpx 20rpx;
  background: #e6f7ff;
  color: #1890ff;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 按钮 */
.search-btn {
  background: #722ed1;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.achievement-btn {
  background: #faad14;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.quiz-btn {
  background: #13c2c2;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.notebook-btn {
  background: #faad14;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.setting-btn {
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.remind-btn {
  background: #fa8c16;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-bottom: 20rpx;
}

.clear-btn {
  background: #fff;
  border: 2rpx solid #ff4d4f;
  color: #ff4d4f;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.clear-btn:active {
  background: #fff1f0;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx;
}

.footer text {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 10rpx;
}
