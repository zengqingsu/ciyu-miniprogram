<!--pages/export/export.wxml-->
<view class="container">
  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card">
      <text class="stat-value">{{stats.words}}</text>
      <text class="stat-label">单词数</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.records}}</text>
      <text class="stat-label">学习记录</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.progress}}</text>
      <text class="stat-label">进度</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.reviews}}</text>
      <text class="stat-label">复习计划</text>
    </view>
  </view>

  <!-- 同步状态 -->
  <view class="sync-section">
    <view class="sync-info">
      <text>上次同步: {{lastSyncTime}}</text>
      <text>待同步: {{pendingChanges}} 条</text>
    </view>
    <button class="sync-btn" bindtap="onSync" loading="{{isExporting}}">同步数据</button>
  </view>

  <!-- 导出选项 -->
  <view class="export-section">
    <text class="section-title">导出数据</text>
    <text class="section-desc">将您的学习数据导出为JSON文件，方便备份或迁移</text>
    
    <button class="export-btn" bindtap="exportToJSON" loading="{{isExporting}}">
      📥 导出为JSON文件
    </button>
  </view>

  <!-- 数据管理 -->
  <view class="danger-section">
    <text class="section-title">危险操作</text>
    <text class="section-desc" style="color: #ff6b6b;">清除数据将删除所有本地存储的学习记录</text>
    
    <button class="clear-btn" bindtap="onClearData">清除所有数据</button>
  </view>

  <!-- 版本信息 -->
  <view class="version-section">
    <text>词途小程序 v1.8</text>
    <text>离线学习 · 智能同步</text>
  </view>
</view>