/* pages/radar/radar.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 0 0 120rpx;
}

.header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
}

.chart-container {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.radar-canvas {
  width: 100%;
  height: 500rpx;
}

.stats-container {
  display: flex;
  justify-content: space-around;
  padding: 30rpx;
  margin: 0 30rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-card {
  flex: 1;
  text-align: center;
  padding: 20rpx;
}

.stat-value {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  color: #409eff;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.detail-container {
  background: #fff;
  margin: 30rpx;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.detail-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.detail-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.detail-category {
  width: 100rpx;
  font-size: 26rpx;
  color: #333;
}

.detail-progress {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #409eff, #67c23a);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.detail-percent {
  font-size: 24rpx;
  color: #409eff;
  width: 70rpx;
  text-align: right;
}

.detail-count {
  font-size: 24rpx;
  color: #999;
  width: 80rpx;
  text-align: right;
}

.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.share-btn {
  width: 100%;
  background: linear-gradient(135deg, #409eff, #67c23a);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 500;
}