<!-- pages/radar/radar.wxml -->
<view class="container">
  <view class="header">
    <text class="title">词汇掌握度</text>
    <text class="subtitle">六维能力雷达图</text>
  </view>

  <!-- 雷达图 -->
  <view class="chart-container">
    <canvas type="2d" id="radarCanvas" class="radar-canvas"></canvas>
  </view>

  <!-- 统计数据 -->
  <view class="stats-container" wx:if="{{stats}}">
    <view class="stat-card">
      <text class="stat-value">{{stats.totalLearned}}</text>
      <text class="stat-label">已掌握</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.newWords}}</text>
      <text class="stat-label">今日新学</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.streak}}</text>
      <text class="stat-label">连续天数</text>
    </view>
  </view>

  <!-- 类别详情 -->
  <view class="detail-container" wx:if="{{radarData && radarData.stats}}">
    <view class="detail-title">各类别详情</view>
    <view class="detail-list">
      <view class="detail-item" wx:for="{{radarData.stats}}" wx:key="category">
        <text class="detail-category">{{item.category}}</text>
        <view class="detail-progress">
          <view class="progress-bar">
            <view class="progress-fill" style="width: {{item.value}}%"></view>
          </view>
          <text class="detail-percent">{{item.value}}%</text>
        </view>
        <text class="detail-count">{{item.known}}/{{item.total}}</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="action-bar">
    <button class="share-btn" bindtap="onShareAppMessage" open-type="share">分享给好友</button>
  </view>
</view>