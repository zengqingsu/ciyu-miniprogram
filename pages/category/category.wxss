/* pages/category/category.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  color: #fff;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
}

/* 难度筛选 */
.level-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.level-btn {
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 24rpx;
  background: #f5f5f5;
  border-radius: 30rpx;
}

.level-btn.active {
  color: #fff;
  background: #667eea;
}

.category-list {
  padding: 20rpx;
}

.category-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.category-icon {
  font-size: 50rpx;
  margin-right: 20rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.category-count {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.category-arrow {
  font-size: 36rpx;
  color: #ccc;
}
