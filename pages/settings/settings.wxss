/* pages/settings/settings.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.input-group {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.input {
  border: 1rpx solid #ddd;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.hint {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.test-btn, .sync-btn {
  background: #667eea;
  color: #fff;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.result {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-top: 15rpx;
}

.sync-info, .network-status, .storage-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.sync-info text,
.network-status text,
.storage-info text {
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
}

.clear-btn {
  background: #ff6b6b;
  color: #fff;
}

.cloud-sync-btn, .smart-sync-btn {
  background: #667eea;
  color: #fff;
  margin-right: 10rpx;
  flex: 1;
}

.view-cloud-btn {
  background: #764ba2;
  color: #fff;
  margin-bottom: 20rpx;
}

.export-btn {
  background: #4caf50;
  color: #fff;
  margin-right: 10rpx;
  flex: 1;
}

.status {
  color: #667eea;
  font-weight: bold;
}

.save-btn {
  background: #52c41a;
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 12rpx;
  margin-top: 40rpx;
}

.save-btn text {
  font-size: 32rpx;
  font-weight: bold;
}

/* v1.8 新样式 */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.switch-row:last-child {
  border-bottom: none;
}

.switch-label {
  font-size: 28rpx;
  color: #333;
}

.button-row {
  display: flex;
  gap: 10rpx;
  margin: 20rpx 0;
}

.network-status {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #667eea;
  font-weight: bold;
}

.storage-info {
  background: #f8f9fa;
  padding: 20rpx;
  border-radius: 8rpx;
  margin: 20rpx 0;
}

.version-info {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  margin-bottom: 10rpx;
}
